        ".read": true,
        ".write": false
      }
    },
    "draft_answers": {
      ".read": false,
      ".write": false
    },
    "submissions": {
      ".read": false,
      ".write": false
    },
    "roster": {
      ".read": false,
      ".write": false
    },
    "sessions": {
      ".read": false,
      ".write": false
    },
    "active_sessions": {
      ".read": false,
      ".write": false
    },
    "devices": {
      ".read": false,
      ".write": false
    },
    "logs": {
      ".read": false,
      ".write": false
    }
  }
}
